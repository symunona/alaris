{
  "name": "alaris",
  "description": "Alaris blog engine",
  "version": "0.0.1",
  "author": {
    "name": "Symunona",
    "email": "symunona@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/symunona/alaris"
  },
  "main": "./app.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "bash -lc 'set -euo pipefail; node bundle-vendor.js; node app.js & SERVER=$!; vite build --watch & BUILD=$!; trap \"kill $SERVER $BUILD\" EXIT INT TERM; wait -n $SERVER $BUILD'",
    "build:weeks": "vite build",
    "build:vendor": "node bundle-vendor.js",
    "build": "pnpm run build:vendor && pnpm run build:weeks"
  },
  "dependencies": {
    "@fengyuanchen/datepicker": "^0.6.5",
    "body-parser": "^1.18.3",
    "bootstrap": "^4.1.1",
    "dropzone": "^5.4.0",
    "express": "^4.16.3",
    "express-basic-auth": "^1.1.5",
    "less-middleware": "3.0.0",
    "moment": "2.22.2",
    "multer": "1.4.4-lts.1",
    "pug": "^3.0.3",
    "solid-js": "^1.8.0",
    "trumbowyg": "^2.10.0",
    "underscore": "^1.8.3",
    "uuid": "^3.2.1",
    "vite": "^4.5.0"
  },
  "devDependencies": {
    "terser": "^5.44.1",
    "vite-plugin-solid": "^2.7.0"
  },
  "readmeFilename": "README.md"
}
